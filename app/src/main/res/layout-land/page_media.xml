<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- IMAGE MODE -->
    <FrameLayout
        android:id="@+id/imageMode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <com.github.chrisbanes.photoview.PhotoView
            android:id="@+id/photoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="centerInside"
            tools:src="@drawable/cervexa_logo"/>

        <!-- AI Analysis Button -->
        <LinearLayout
            android:id="@+id/btnAnalisisAi"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/bg_ai_toggle_off"
            android:clickable="true"
            android:elevation="6dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="AI Icon"
                android:src="@drawable/ic_ai_toggle"
                app:tint="#888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analisis AI"
                android:textColor="#888888"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Remove Overlay Button (hidden by default) -->
        <LinearLayout
            android:id="@+id/btnHapusOverlay"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/bg_ai_toggle_on"
            android:clickable="true"
            android:elevation="6dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="AI Icon"
                android:src="@drawable/ic_ai_toggle"
                app:tint="#00C853" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hapus Overlay"
                android:textColor="#00C853"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- AI Loading Indicator -->
        <ProgressBar
            android:id="@+id/pbAiLoading"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:elevation="8dp"
            android:visibility="gone" />

        <!-- Overlay bawah gambar -->
        <LinearLayout
            android:id="@+id/overlayImage"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:visibility="gone"
            android:background="@drawable/bg_overlay_bottom_rounded">

            <TextView
                android:id="@+id/tvInfoLeft"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                tools:text="Ferry Irwandi (35) 3211234567891043"/>

            <TextView
                android:id="@+id/tvInfoRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                tools:text="17/06/2025 10:12:49"/>
        </LinearLayout>
    </FrameLayout>

    <!-- VIDEO MODE -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/videoMode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <VideoView
            android:id="@+id/vvPreview"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="16:9" />
        <!-- Rasio awal 16:9 akan diganti ke W:H asli saat onPrepared -->

