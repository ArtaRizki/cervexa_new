<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/csVideoImage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@android:color/black"
    android:theme="@style/AppTheme.Land.NoActionBar">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ✅ Video FULL SCREEN di landscape — VLC TextureView -->
    <FrameLayout
        android:id="@+id/videoContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextureView
            android:id="@+id/textureView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- ✅ Overlay INFO - constraint ke PARENT, bukan ivVideoImage -->
    <TextView
        android:id="@+id/tvOverlayInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#DD000000"
        android:elevation="5dp"
        android:fontFamily="monospace"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:text="Nama RS / NRM"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ✅ Overlay CLOCK - DIMODIFIKASI untuk menutupi timestamp kuning -->
    <TextView
        android:id="@+id/tvOverlayClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#DD000000"
        android:elevation="5dp"
        android:fontFamily="monospace"
        android:paddingHorizontal="50dp"
        android:paddingVertical="6dp"
        android:text="0000-00-00 00:00:00"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/vShutterImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/black"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/pbLoadingImage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:indeterminateTint="@android:color/white"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ✅ Tombol BACK -->
    <ImageButton
        android:id="@+id/btnBackLite"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_margin="20dp"
        android:background="@drawable/bg_btn_remote_selector"
        android:contentDescription="Kembali"
        android:elevation="4dp"
        android:padding="14dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <!-- AI Toggle Button -->
    <LinearLayout
        android:id="@+id/btnAiToggle"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_margin="20dp"
        android:background="@drawable/bg_ai_toggle_off"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        app:layout_constraintEnd_toStartOf="@id/sideControls"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivAiIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="AI Icon"
            android:src="@drawable/ic_ai_toggle"
            app:tint="#888888" />

        <TextView
            android:id="@+id/tvAiToggleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI OFF"
            android:textColor="#888888"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ✅ HUD Recording -->
    <LinearLayout
        android:id="@+id/recordHud"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_record_hud"
        android:elevation="4dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_record_dot" />

        <TextView
            android:id="@+id/tvRecordTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="00:00:00"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <!-- ✅ Side Controls (Video + Snapshot) -->
    <LinearLayout
        android:id="@+id/sideControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:elevation="4dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnRecordVideo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_btn_remote_selector"
            android:clickable="true"
            android:contentDescription="Record Video"
            android:padding="18dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_video"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnSnapshot"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_btn_remote_selector"
            android:clickable="true"
            android:contentDescription="Snapshot"
            android:padding="18dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_camera"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- ✅ GANTI ID DARI bnStartStopImage ke bnStartStopImageLand -->
    <ImageButton
        android:id="@+id/bnStartStopImageLand"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:saveEnabled="false"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <!-- Hidden elements untuk compatibility -->
    <TextView
        android:id="@+id/tvStamp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvThumbs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <Button
        android:id="@+id/btnSimpanCase"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tvStatusImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tvMediaTgl"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tvEmptyThumbs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <ImageView
        android:id="@+id/tvImgNoMedia"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tvImgSubtitleNoMedia"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tvMedia"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tvStatistics2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <ImageButton
        android:id="@+id/btnEnterLandscape"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints" />

</androidx.constraintlayout.widget.ConstraintLayout>