<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Stream ImageView — fullscreen, center crop -->
    <ImageView
        android:id="@+id/iv_ms2_stream"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="MS2 Camera Stream" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/pb_ms2_loading"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="visible" />

    <!-- Status / error text -->
    <TextView
        android:id="@+id/tv_ms2_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="80dp"
        android:gravity="center"
        android:padding="24dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4"
        android:text="Menghubungkan ke kamera MS2..."
        android:visibility="visible" />

    <!-- Top bar overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="#80000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_ms2_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Kembali"
            android:tint="#FFFFFF" />

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Kamera MS2 — Live Stream"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <!-- Spacer matching back button width -->
        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />

    </LinearLayout>

    <!-- Bottom controls overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#80000000"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Capture button -->
        <ImageButton
            android:id="@+id/btn_ms2_capture"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@android:drawable/ic_menu_camera"
            android:contentDescription="Ambil Gambar"
            android:scaleType="fitCenter"
            android:padding="8dp" />

    </LinearLayout>

</FrameLayout>
