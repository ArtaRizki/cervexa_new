<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <!-- ══ Konten Utama ══════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header / App Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:background="#1565C0"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="16dp"
                android:elevation="4dp">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/material_ic_keyboard_arrow_left_black_24dp"
                    android:tint="#FFFFFF"
                    android:contentDescription="Kembali" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Registrasi Pasien"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <!-- Logo Cervexa kecil di kanan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CERVEXA"
                    android:textColor="#90CAF9"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <!-- Ilustrasi / Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1565C0"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="48sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Isi data pasien sebelum memulai pemeriksaan"
                    android:textColor="#BBDEFB"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingTop="4dp" />

            </LinearLayout>

            <!-- Card Form -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Nama Lengkap -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data Diri Pasien"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:paddingBottom="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNama"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nama Lengkap *"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNama"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords"
                            android:imeOptions="actionNext"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- NIK -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNik"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="NIK (16 digit) *"
                        app:helperText="Nomor Induk Kependudukan"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNik"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:imeOptions="actionNext"
                            android:maxLength="16"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Tanggal Lahir -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDob"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tanggal Lahir *"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/material_ic_menu_arrow_down_black_24dp"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDob"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E3F2FD"
                        android:layout_marginBottom="16dp" />

                    <!-- Data Institusi -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data Institusi"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:paddingBottom="12dp" />

                    <!-- Nama Rumah Sakit -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRS"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nama Rumah Sakit / Klinik *"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRS"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:imeOptions="actionNext"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Nomor Rekam Medis (opsional) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNrm"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="No. Rekam Medis (opsional)"
                        app:helperText="Kosongkan jika belum ada"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNrm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:imeOptions="actionDone"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Tombol Daftar & Mulai -->
                    <Button
                        android:id="@+id/btnDaftar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Mulai Pemeriksaan →"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:backgroundTint="#1565C0"
                        android:textColor="#FFFFFF"
                        style="@style/Widget.MaterialComponents.Button" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Info Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="* Data disimpan secara lokal di perangkat"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:paddingBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ══ Loading Overlay ════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <androidx.core.widget.ContentLoadingProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            style="?android:progressBarStyleLarge"
            android:indeterminateTint="#FFFFFF" />

    </FrameLayout>

</FrameLayout>
