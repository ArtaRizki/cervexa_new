<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <ImageView
        android:id="@+id/ivThumb"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:background="@drawable/rounded_image_12"
        android:clipToOutline="true"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTime"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- overlay pilih -->
    <View
        android:id="@+id/selOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_sel_overlay"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ivThumb"
        app:layout_constraintBottom_toBottomOf="@id/ivThumb"
        app:layout_constraintStart_toStartOf="@id/ivThumb"
        app:layout_constraintEnd_toEndOf="@id/ivThumb"/>

    <ImageView
        android:id="@+id/selCheck"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_margin="8dp"
        android:background="@drawable/bg_check_circle"
        android:padding="4dp"
        android:visibility="gone"
        android:src="@drawable/ic_check_circle"
        app:layout_constraintTop_toTopOf="@id/ivThumb"
        app:layout_constraintEnd_toEndOf="@id/ivThumb"
        app:tint="@android:color/white" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10:32"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintTop_toBottomOf="@id/ivThumb"
        app:layout_constraintStart_toStartOf="@id/ivThumb"/>
</androidx.constraintlayout.widget.ConstraintLayout>