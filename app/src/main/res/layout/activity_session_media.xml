<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorWhite"
    tools:context=".gallery.SessionMediaActivity">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorWhite"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/menu_session_media"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:popupTheme="@style/ToolbarPopupTheme"
        app:title="Nama Pasien"
        app:titleTextAppearance="@style/CustomToolbarTitle"
        app:titleTextColor="@color/colorBlack" />

    <!-- RecyclerView — langsung di bawah toolbar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSessionMedia"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        tools:listitem="@layout/item_thumb" />

    <!-- Bottom action bar — GONE saat normal, VISIBLE hanya saat mode pilih -->
    <LinearLayout
        android:id="@+id/bottomActionBar"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@color/colorWhite"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Tombol Bagikan -->
        <LinearLayout
            android:id="@+id/btnShareWrapper"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnShareBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Bagikan"
                android:src="@drawable/ic_share_alt"
                app:tint="#616161" />

            <TextView
                android:id="@+id/tvBtnShare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bagikan"
                android:textColor="#555555" />
        </LinearLayout>

        <!-- Tombol Hapus -->
        <LinearLayout
            android:id="@+id/btnDeleteWrapper"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnDeleteBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Hapus"
                android:src="@drawable/ic_delete"
                app:tint="#616161" />

            <TextView
                android:id="@+id/tvBtnDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hapus"
                android:textColor="#555555" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>