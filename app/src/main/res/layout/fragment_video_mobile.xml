<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/csVideoImage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@color/colorWhite"
    tools:context="live.VideoFragment">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorWhite"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/menu_video_fragment"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:popupTheme="@style/ToolbarPopupTheme"
        app:title="Cervexa Colposcope"
        app:titleCentered="false"
        app:titleTextAppearance="@style/CustomToolbarTitle" />

    <!-- Garis pemisah -->
    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D9D9D9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar" />

    <!-- Shutter HANYA nempel ke area video -->
    <View
        android:id="@+id/vShutterImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/black"
        android:elevation="2dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/videoContainer"
        app:layout_constraintEnd_toEndOf="@id/videoContainer"
        app:layout_constraintStart_toStartOf="@id/videoContainer"
        app:layout_constraintTop_toTopOf="@id/videoContainer" />

    <FrameLayout
        android:id="@+id/videoContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topAppBar">

        <TextureView
            android:id="@+id/textureView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvOverlayInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#DD000000"
        android:elevation="5dp"
        android:fontFamily="monospace"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="Nama RS / NRM"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/videoContainer"
        app:layout_constraintStart_toStartOf="@id/videoContainer" />

    <TextView
        android:id="@+id/tvOverlayClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        android:background="#DD000000"
        android:elevation="5dp"
        android:fontFamily="monospace"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="2025-06-17 10:12:49"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/videoContainer"
        app:layout_constraintEnd_toEndOf="@id/videoContainer" />

    <!-- AI Toggle Button -->
    <LinearLayout
        android:id="@+id/btnAiToggle"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_margin="8dp"
        android:background="@drawable/bg_ai_toggle_off"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        app:layout_constraintEnd_toEndOf="@id/videoContainer"
        app:layout_constraintTop_toTopOf="@id/videoContainer">

        <ImageView
            android:id="@+id/ivAiIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="AI Icon"
            android:src="@drawable/ic_ai_toggle"
            app:tint="#888888" />

        <TextView
            android:id="@+id/tvAiToggleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI OFF"
            android:textColor="#888888"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Progress HANYA di tengah area video -->
    <ProgressBar
        android:id="@+id/pbLoadingImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="3dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/videoContainer"
        app:layout_constraintEnd_toEndOf="@id/videoContainer"
        app:layout_constraintStart_toStartOf="@id/videoContainer"
        app:layout_constraintTop_toTopOf="@id/videoContainer" />

    <TextView
        android:id="@+id/tvStatistics2"
        android:layout_width="233dp"
        android:layout_height="93dp"
        android:layout_marginTop="396dp"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bottomControls" />

    <Button
        android:id="@+id/bnStartStopImage"
        android:layout_width="125dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:layout_marginBottom="76dp"
        android:text="Start"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.944"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvStatusImage"
        android:layout_width="309dp"
        android:layout_height="101dp"
        android:layout_marginTop="284dp"
        android:gravity="end"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bottomControls" />

    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="@drawable/border_bottom_rounded"
        android:gravity="center"
        android:orientation="horizontal"
        app:flow_horizontalAlign="end"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/videoContainer">


        <ImageButton
            android:id="@+id/btnSnapshot"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="60dp"
            android:layout_marginEnd="60dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="ShutterImage"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_camera" />

        <ImageButton
            android:id="@+id/btnRecordVideo"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="60dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="Record Video"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_video" />

        <ImageButton
            android:id="@+id/imageButton3"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="60dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="Resolution"
            android:scaleType="centerCrop"
            android:src="@drawable/frame_592"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnEnterLandscape"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="60dp"
            android:adjustViewBounds="true"
            android:background="@null"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="Fullscreen"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_fullscreen" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvThumbs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="64dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/btnSimpanCase"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bottomControls"
        app:layout_constraintVertical_bias="0.107" />

    <!-- HUD Rekaman (overlay di atas video) -->
    <LinearLayout
        android:id="@+id/recordHud"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_record_hud"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/videoContainer"
        app:layout_constraintTop_toTopOf="@id/videoContainer">

        <!--        &lt;!&ndash; Titik merah kedip &ndash;&gt;-->
        <!--        <View-->
        <!--            android:id="@+id/dotRec"-->
        <!--            android:layout_width="10dp"-->
        <!--            android:layout_height="10dp"-->
        <!--            android:background="@drawable/dot_red"-->
        <!--            android:layout_marginEnd="8dp" />-->
        <TextView
            android:id="@+id/tvRecordTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEmptyThumbs"
        android:layout_width="355dp"
        android:layout_height="44dp"
        android:fontFamily="@font/manrope_medium"
        android:padding="8dp"
        android:text="Belum ada media"
        android:textAlignment="center"
        android:textColor="#555555"
        android:textSize="18sp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.51"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bottomControls"
        app:layout_constraintVertical_bias="0.11" />

    <ImageView
        android:id="@+id/tvImgNoMedia"
        android:layout_width="124dp"
        android:layout_height="112dp"
        android:layout_marginTop="4dp"
        android:src="@drawable/ic_ooui_image_gallery"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvEmptyThumbs" />

    <TextView
        android:id="@+id/tvImgSubtitleNoMedia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/manrope_medium"
        android:text="Media yang Anda ambil akan tampil di sini"
        android:textColor="#999999"
        android:textSize="12sp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvImgNoMedia" />

    <Button
        android:id="@+id/btnSimpanCase"
        android:layout_width="0dp"
        android:layout_height="52sp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:layout_marginBottom="24dp"
        android:text="Simpan"
        android:textColor="@color/colorWhite"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvMedia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:text="Media Terekam"
        android:textColor="@color/colorBlack"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bottomControls" />

    <TextView
        android:id="@+id/tvMediaTgl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="5dp"
        android:text="17/06/2025"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvMedia" />

</androidx.constraintlayout.widget.ConstraintLayout>